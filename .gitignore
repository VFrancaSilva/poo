# --- Executáveis e Binários ---
# Bloqueia ficheiros compilados em Windows, Linux e macOS
*.exe
*.out
*.app
*.bin
*.elf

# --- Objetos e Bibliotecas ---
# Ficheiros intermediários de compilação
*.o
*.obj
*.a
*.lib
*.so
*.dll
*.dylib

# --- Pastas de Build e Ferramentas ---
# Ignora pastas criadas por sistemas como CMake ou IDEs
[Bb]uild/
[Dd]ebug/
[Rr]elease/
bin/
obj/
.cmake/
CMakeCache.txt
CMakeFiles/

# --- Configurações de IDEs (Personalizadas) ---
# Ignora ficheiros do VS Code, Visual Studio e CLion
.vscode/
.vs/
.idea/
*.user
*.suo
*.sln
*.vcxproj

# --- Ficheiros de Sistema e Temporários ---
.DS_Store
Thumbs.db
*.log
*.tmp